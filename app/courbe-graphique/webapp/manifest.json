{
  "_version": "1.59.0",

  "sap.app": {
    "id": "onee.courbes.courbegraphique",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": { "version": "0.0.1" },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}"
  },

  "sap.ui": {
    "technology": "UI5",
    "fullWidth": true,
    "supportedThemes": ["sap_horizon"]
  },

  "sap.ui5": {
    "flexEnabled": false,
    "rootView": {
      "viewName": "onee.courbes.courbegraphique.view.View1",
      "type": "XML",
      "id": "app"
    },
    "dependencies": {
      "minUI5Version": "1.108.0",
      "libs": {
        "sap.m": {},
        "sap.viz": {},
        "sap.ui.layout": {}
      }
    },
    "contentDensities": { "compact": true, "cozy": true },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "onee.courbes.courbegraphique.i18n.i18n"
        }
      }
    }
  },

  "sap.fiori": {
    "registrationIds": [],
    "archeType": "analytical"
  }
}
