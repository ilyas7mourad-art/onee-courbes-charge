<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:vizData="sap.viz.ui5.data"
    xmlns:layout="sap.ui.layout"
    controllerName="onee.courbes.courbegraphique.controller.View1"
    displayBlock="true">

  <Page id="page" title="Courbe de charge" showNavButton="false">
    <content>
      <VBox class="sapUiSmallMargin" width="100%">

        <!-- Sélecteur compteur -->
        <HBox alignItems="Center" class="sapUiSmallMarginBottom">
          <Label text="Compteur (NSF) :" labelFor="cboSerge" class="sapUiSmallMarginEnd" design="Bold"/>
          <ComboBox
            id="cboSerge"
            placeholder="Sélectionner un compteur…"
            selectionChange=".onSergeChange"
            width="220px"/>
        </HBox>

        <!-- Barre de statut -->
        <Text id="txtStatus" text="" class="sapUiTinyMarginBottom" wrapping="false"/>

        <!-- VizFrame — courbe de charge + lignes Pmax -->
        <viz:VizFrame
          id="vizFrame"
          vizType="line"
          height="460px"
          width="100%">
          <viz:dataset>
            <vizData:FlattenedDataset data="{chart>/data}">
              <vizData:dimensions>
                <vizData:DimensionDefinition name="Horodatage" value="{chart>timestamp}"/>
              </vizData:dimensions>
              <vizData:measures>
                <vizData:MeasureDefinition name="Courbe de charge" value="{chart>courbe}"/>
                <vizData:MeasureDefinition name="Pmax PAIHP"       value="{chart>pmaxPAIHP}"/>
                <vizData:MeasureDefinition name="Pmax PAIHC"       value="{chart>pmaxPAIHC}"/>
                <vizData:MeasureDefinition name="Pmax PAIHPL"      value="{chart>pmaxPAIHPL}"/>
              </vizData:measures>
            </vizData:FlattenedDataset>
          </viz:dataset>
          <!-- Les feeds sont ajoutés programmatiquement dans le controller (onInit) -->
        </viz:VizFrame>

      </VBox>
    </content>
  </Page>

</mvc:View>
