{
  "_version": "1.59.0",

  "sap.app": {
    "id": "onee.courbes.calculed",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": { "version": "0.0.1" },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/courbes/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.0"
        }
      }
    }
  },

  "sap.ui": {
    "technology": "UI5",
    "fullWidth": false,
    "supportedThemes": ["sap_horizon"]
  },

  "sap.ui5": {
    "flexEnabled": false,
    "dependencies": {
      "minUI5Version": "1.108.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": { "compact": true, "cozy": true },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "onee.courbes.calculed.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "CalculedList",
          "target": "CalculedList"
        },
        {
          "pattern": "ZccCourbeChargesCalculed({key}):?query:",
          "name": "CalculedObjectPage",
          "target": "CalculedObjectPage"
        }
      ],
      "targets": {
        "CalculedList": {
          "type": "Component",
          "id": "CalculedList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "entitySet": "ZccCourbeChargesCalculed",
              "variantManagement": "None",
              "initialLoad": "Enabled",
              "navigation": {
                "ZccCourbeChargesCalculed": {
                  "detail": { "route": "CalculedObjectPage" }
                }
              }
            }
          }
        },
        "CalculedObjectPage": {
          "type": "Component",
          "id": "CalculedObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "entitySet": "ZccCourbeChargesCalculed",
              "editableHeaderContent": false
            }
          }
        }
      }
    }
  },

  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  }
}
